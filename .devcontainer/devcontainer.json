{
	"name": "wallfruits-backend",
	"image": "mcr.microsoft.com/devcontainers/universal:2",
	"forwardPorts": [8000],
	"portsAttributes": {
		"8000": {
			"label": "WallFruits",
			"onAutoForward": "openPreview"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-edgedevtools.vscode-edge-devtools",
				"auchenberg.vscode-browser-preview"
			]
		}
	}
}