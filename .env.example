# WALLFRUITS - EXEMPLO DE CONFIGURACAO
# Copie para .env e ajuste os valores

# Banco de dados (use a URL do Supabase, preferencialmente do Pooler)
# Exemplo: postgresql://postgres.xxxxx:[SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
STARTUP_DB_RETRIES=5
STARTUP_DB_RETRY_DELAY_SECONDS=2
STRICT_STARTUP=false
HEALTHCHECK_TIMEOUT_SECONDS=3

# Supabase Auth (habilite para usar login/registro via Supabase)
SUPABASE_AUTH_ENABLED=false
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=cole_aqui_sua_anon_key
# Opcional, mas recomendado para criar usuarios pelo backend sem confirmacao de email
SUPABASE_SERVICE_ROLE_KEY=cole_aqui_sua_service_role_key

# Seguranca (GERE UMA CHAVE FORTE!)
SECRET_KEY=cole_aqui_uma_chave_secreta_longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API
API_TITLE=WallFruits API
API_DESCRIPTION=Marketplace inteligente de frutas
API_VERSION=2.0.0
DEBUG=false

# CORS / Hosts (ajuste com seu dominio Render)
CORS_ORIGINS=["https://seu-app.onrender.com"]
ALLOWED_HOSTS=["seu-app.onrender.com"]

# Redis (deixe false no plano gratis)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Webhook opcional para eventos de intermediação (validação/contrato)
INTERMEDIATION_WEBHOOK_URL=
INTERMEDIATION_WEBHOOK_TIMEOUT_SECONDS=5

# Upload e logs
UPLOAD_DIRECTORY=uploads
MAX_FILE_SIZE=10485760
MAX_CONTRACT_FILE_SIZE=15728640
ALLOWED_CONTRACT_EXTENSIONS=["pdf","doc","docx","png","jpg","jpeg"]
LOG_LEVEL=INFO
