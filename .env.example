# WALLFRUITS - EXEMPLO DE CONFIGURACAO
# Copie para .env e ajuste os valores

# Banco de dados (Render fornece automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/database

# Seguranca (GERE UMA CHAVE FORTE!)
SECRET_KEY=cole_aqui_uma_chave_secreta_longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API
API_TITLE=WallFruits API
API_DESCRIPTION=Marketplace inteligente de frutas
API_VERSION=2.0.0
DEBUG=false

# CORS / Hosts (ajuste com seu dominio Render)
CORS_ORIGINS=["https://seu-app.onrender.com"]
ALLOWED_HOSTS=["seu-app.onrender.com"]

# Redis (deixe false no plano gratis)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Upload e logs
UPLOAD_DIRECTORY=uploads
MAX_FILE_SIZE=10485760
LOG_LEVEL=INFO
